# 🐉 EldritchDM — Example .env
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (which is git-ignored) and fill in your values.
# Created by Jeremy Schoemaker (shoemoney) · MIT licensed · 2026
# ────────────────────────────────────────────────────────────────────────────
#
# 🔑 LEGEND
#   ✅ = required, the bot won't start without it
#   ⚙️ = optional, but you might want to change it
#   🧪 = developer / advanced
#
# ════════════════════════════════════════════════════════════════════════════
# 🤖 DISCORD
# ════════════════════════════════════════════════════════════════════════════

# ✅ Your Discord bot token from https://discord.com/developers/applications.
# Treat this like a password. NEVER commit it. NEVER paste it in chat.
# If it leaks, regenerate immediately in the Developer Portal.
DISCORD_TOKEN=replace-me-with-your-discord-bot-token

# ⚙️ Optional: Discord application id (used by some slash-command sync tooling).
# Leave blank to let discord.py figure it out from the token.
# DISCORD_APPLICATION_ID=

# ⚙️ Optional: comma-separated guild IDs to register slash commands to instantly.
# If unset, commands register globally (can take up to 1 hour to propagate).
# Recommended for dev: set this to your test server's ID.
# DISCORD_GUILD_IDS=

# ════════════════════════════════════════════════════════════════════════════
# 🧠 oMLX — LOCAL INFERENCE SERVER
# ════════════════════════════════════════════════════════════════════════════
# EldritchDM expects an oMLX server to be running locally, hosting the
# `ShoeGPT` model AND exposing the dm20 MCP toolbox.
#
# If you don't have one yet:
#   1) Install: https://github.com/macabdul9/omlx
#   2) Load a model: `omlx serve --model ShoeGPT` (or whatever you named it)
#   3) Confirm dm20 is exposed: `curl :8765/v1/mcp/tools | jq '. | length'`
#
# On Jeremy's reference rig oMLX is supervised by launchd as `com.user.omlx`.
# ────────────────────────────────────────────────────────────────────────────

# ⚙️ Base URL for the OpenAI-compatible chat API.
# Used for narration and character-sheet schema translation.
OMLX_ENDPOINT=http://localhost:8765/v1

# ⚙️ The model id the bot will request from oMLX for narration.
# This must already be loaded in your oMLX server (check `/v1/models`).
# Default `ShoeGPT` matches Jeremy's setup (Gemma 4 4-bit under the hood).
OMLX_MODEL=ShoeGPT

# ⚙️ Endpoint that runs MCP tool calls — this is where the bot's
# game-mechanic requests go. The bot expects dm20's 97 tools to be available.
MCP_EXECUTE_URL=http://localhost:8765/v1/mcp/execute

# ⚙️ Endpoint that lists available MCP tools. Used by health checks
# and the `/ping` slash command.
MCP_TOOLS_URL=http://localhost:8765/v1/mcp/tools

# 🧪 Minimum interval (milliseconds) between mutating MCP calls per channel.
# Implements OPS-03 — prevents dm20 thrashing under spam clicks. Matches the
# Settings default (200ms). Lower = snappier but riskier; higher = safer.
MCP_RATE_LIMIT_MS=200

# 🧪 Seconds between oMLX health pings. Lower = faster failover, more traffic.
OMLX_HEALTH_INTERVAL=60

# 🧪 Consecutive ping failures before circuit breaker opens.
# When open, the bot replies "🔌 DM is offline" to every interaction
# until oMLX recovers. Auto-closes on next successful ping.
OMLX_CIRCUIT_BREAKER_THRESHOLD=3

# 🧪 Override the model used for character-sheet OCR translation
# (low-temperature JSON mode). Defaults to OMLX_MODEL if unset.
# OMLX_INGEST_MODEL=

# ════════════════════════════════════════════════════════════════════════════
# 💾 LOCAL PERSISTENCE (Discord-state only — NOT gameplay state)
# ════════════════════════════════════════════════════════════════════════════
# This is the small SQLite that holds Discord-specific bookkeeping:
# channel↔campaign mappings, persistent view registry, riposte timers,
# sanitizer audit log. Gameplay state lives in dm20's `~/.omlx/dm.db`.
# ────────────────────────────────────────────────────────────────────────────

# ⚙️ Path to the EldritchDM local SQLite. Created on first run by bootstrap.
ELDRITCH_DB_PATH=./eldritch.sqlite3

# 🧪 Override SQLite busy_timeout (milliseconds). Default is fine for almost all setups.
# ELDRITCH_DB_BUSY_TIMEOUT_MS=5000

# 🧪 Periodic WAL checkpoint interval (seconds). 0 = disabled (not recommended).
# ELDRITCH_DB_CHECKPOINT_INTERVAL=600

# ════════════════════════════════════════════════════════════════════════════
# 📝 LOGGING
# ════════════════════════════════════════════════════════════════════════════

# ⚙️ DEBUG / INFO / WARNING / ERROR
# Use DEBUG when filing a bug report.
LOG_LEVEL=INFO

# ⚙️ `json` (structlog JSON for production) or `console` (pretty colored for dev)
LOG_FORMAT=console

# 🧪 Optional log file path. If unset, logs to stderr only.
# LOG_FILE=./eldritch.log

# ════════════════════════════════════════════════════════════════════════════
# 🎮 GAMEPLAY KNOBS
# ════════════════════════════════════════════════════════════════════════════

# ⚙️ How long the riposte timed button stays clickable. 8s is the PRD default.
# Increase if your players have slow connections; decrease for tighter pacing.
RIPOSTE_TTL_SECONDS=8

# ⚙️ Max Discord embed edits per second per message (combat coalescer).
# Discord limits edits at ~5/5s per channel — keep this ≤1.0 to be safe.
EMBED_EDIT_RATE_LIMIT=1.0

# ⚙️ Hard cap on player free-text in modal inputs. Bigger = more verbose;
# smaller = less prompt-injection surface. 500 is a reasonable middle ground.
MAX_MODAL_INPUT_CHARS=500

# ⚙️ How long to wait for additional player intents before resolving
# an exploration batch. 30s = generous for thoughtful players.
EXPLORE_BATCH_WINDOW_SECONDS=30

# ════════════════════════════════════════════════════════════════════════════
# 🌐 dm20 PARTY MODE
# ════════════════════════════════════════════════════════════════════════════
# The bot binds to dm20's Party Mode queue per channel. This lets you mix
# Discord-mode and browser-mode players in the same session (eventually).
# ────────────────────────────────────────────────────────────────────────────

# ⚙️ Port dm20 Party Mode HTTP server listens on. Discord-only sessions can
# leave this alone. If you actually want browser players, make sure it's
# reachable from their network (port-forward, tailscale, etc.).
PARTY_MODE_PORT=8080

# 🧪 Polling interval (milliseconds) for dm20__party_pop_action.
# Lower = snappier, higher = nicer to your CPU. 250ms is a sweet spot.
PARTY_POLL_INTERVAL_MS=250

# ════════════════════════════════════════════════════════════════════════════
# 🧪 DEV / TEST
# ════════════════════════════════════════════════════════════════════════════

# 🧪 Set to 1 to enable the slow stress tests (`pytest -m slow`).
# Off by default to keep `pytest` fast.
# RUN_STRESS=0

# 🧪 If 1, the sanitizer logs EVERY input (even clean ones). Noisy. Useful
# when chasing injection attempts. Off by default.
# SANITIZER_VERBOSE_AUDIT=0

# 🧪 NOTE: oMLX cache strategy (formerly OMLX_CACHE_STRATEGY) is configured
# on the oMLX server side, NOT via this .env. Pass it when you start oMLX:
#     omlx serve --cache-strategy <strategy>
# EldritchDM does not consume this env var (no matching Settings field).

# ────────────────────────────────────────────────────────────────────────────
# 🎲 That's it. Save the file as `.env`, run `python -m eldritch_dm.bootstrap`,
# then `python run.py`. Roll initiative.
# ────────────────────────────────────────────────────────────────────────────
